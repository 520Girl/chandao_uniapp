# 接口加密配置
VITE_SECURITY_ENABLE=false
VITE_SECURITY_SECRET_KEY=CHANGE_ME_TEMPLATE_KEY
VITE_SECURITY_ENCRYPT_METHODS=POST,PUT,PATCH,DELETE

#小程序名称
VITE_APP_NAME="坐观其心"

# H5 分享基础 URL
VITE_H5_SHARE_BASE="http://192.168.31.78:8001"

# 禅修后台静音：包内 /static/silence.mp3 异常时可改网络地址（本机仅模拟器 + 关闭域名校验可测 http）
