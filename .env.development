VITE_APP_TITLE=uniapp-dev
VITE_API_BASE_URL="http://192.168.31.78:8001"
VITE_UPLOAD_BASE_URL="http://192.168.31.78:8001"
VITE_API_VERSION="/api"
VITE_API_TIMEOUT=20000

# 逗号分隔，支持写域名或带协议地址（内部会归一化成 hostname）
